# =============================================================================
# IAC-Ansible: ansible-pull systemd service
# Managed by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

[Unit]
Description=IAC-Ansible Pull Configuration from Git
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/ansible-pull \
  --url {{ ansible_pull_repo_url }} \
  --checkout {{ ansible_pull_branch }} \
  --directory {{ ansible_pull_workdir }} \
  --inventory {{ ansible_pull_inventory }} \
  --full \
{% if ansible_pull_vault_password_file | default('') | length > 0 %}
  --vault-password-file {{ ansible_pull_vault_password_file }} \
{% endif %}
  {{ ansible_pull_playbook }}{{ ' ' + ansible_pull_extra_args if ansible_pull_extra_args | default('') | length > 0 else '' }}
StandardOutput=append:{{ ansible_pull_log_file }}
StandardError=append:{{ ansible_pull_log_file }}
TimeoutStartSec=1800
Environment="ANSIBLE_LOG_PATH={{ ansible_pull_log_file }}"
Environment="HOME=/root"

# Security hardening (limited: ansible-pull needs root + /root write access)
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes

[Install]
WantedBy=multi-user.target
