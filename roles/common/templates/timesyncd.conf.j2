# =============================================================================
# IAC-Ansible: systemd-timesyncd configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

[Time]
NTP={{ common_ntp_servers | join(' ') }}
{% if common_ntp_fallback_servers is defined and common_ntp_fallback_servers | length > 0 %}
FallbackNTP={{ common_ntp_fallback_servers | join(' ') }}
{% endif %}

RootDistanceMaxSec={{ common_ntp_root_distance_max_sec }}
PollIntervalMinSec={{ common_ntp_poll_interval_min_sec }}
PollIntervalMaxSec={{ common_ntp_poll_interval_max_sec }}
ConnectionRetrySec={{ common_ntp_connection_retry_sec }}
SaveIntervalSec={{ common_ntp_save_interval_sec }}
