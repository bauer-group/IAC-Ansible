# =============================================================================
# IAC-Ansible: systemd-timesyncd configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

[Time]
NTP={{ ntp_servers | join(' ') }}
{% if ntp_fallback_servers is defined and ntp_fallback_servers | length > 0 %}
FallbackNTP={{ ntp_fallback_servers | join(' ') }}
{% endif %}

RootDistanceMaxSec={{ common_ntp_root_distance_max_sec | default(5) }}
PollIntervalMinSec={{ common_ntp_poll_interval_min_sec | default(32) }}
PollIntervalMaxSec={{ common_ntp_poll_interval_max_sec | default(2048) }}
ConnectionRetrySec={{ common_ntp_connection_retry_sec | default(30) }}
SaveIntervalSec={{ common_ntp_save_interval_sec | default(60) }}
