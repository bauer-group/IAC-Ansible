# =============================================================================
# IAC-Ansible: chrony main configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# -----------------------------------------------------------------------------
# Custom NTP sources  -> {{ common_chrony_sourcedir }}/99-iac.sources
# Custom tuning       -> {{ common_chrony_confdir }}/99-iac.conf
# Distribution sources (e.g. ubuntu-ntp-pools.sources with NTS) are picked
# up via sourcedir below and act as fallback when our own servers are
# unreachable.
# =============================================================================

# Modular config: load every *.conf in confdir and every *.sources in
# sourcedir (distro pools + our drop-ins).
confdir {{ common_chrony_confdir }}
sourcedir {{ common_chrony_sourcedir }}
{% if common_chrony_sourcedir != '/run/chrony-dhcp' %}
sourcedir /run/chrony-dhcp
{% endif %}

# Persistence + NTS key storage
driftfile {{ common_chrony_driftfile }}
ntsdumpdir /var/lib/chrony

# Logging + leap-second handling
logdir /var/log/chrony
leapsectz right/UTC

# Safety directives (distribution defaults)
maxupdateskew 100.0
rtcsync
makestep 1 3
