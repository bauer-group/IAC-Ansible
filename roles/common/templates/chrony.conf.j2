{# -----------------------------------------------------------------------------
   IAC-Ansible: chrony configuration
   Managed by Ansible - DO NOT EDIT MANUALLY
   Poll interval bounds translated from common_ntp_poll_interval_{min,max}_sec
   (log2 seconds -- chrony's minpoll/maxpoll are powers of two).
----------------------------------------------------------------------------- #}
# =============================================================================
# IAC-Ansible: chrony configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

{% set minpoll = (common_ntp_poll_interval_min_sec | int | log(2)) | round(0, 'floor') | int %}
{% set maxpoll = (common_ntp_poll_interval_max_sec | int | log(2)) | round(0, 'floor') | int %}
{% for server in common_ntp_servers -%}
server {{ server }} iburst minpoll {{ minpoll }} maxpoll {{ maxpoll }}
{% endfor -%}
{% if common_ntp_fallback_servers is defined and common_ntp_fallback_servers | length > 0 %}
{% for server in common_ntp_fallback_servers -%}
server {{ server }} iburst minpoll {{ minpoll }} maxpoll {{ maxpoll }}
{% endfor -%}
{% endif %}

driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
maxdistance {{ common_ntp_root_distance_max_sec }}
