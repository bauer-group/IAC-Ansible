# =============================================================================
# IAC-Ansible: chrony main configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# -----------------------------------------------------------------------------
# Custom NTP sources  → /etc/chrony/sources.d/99-iac.sources
# Custom tuning       → /etc/chrony/conf.d/99-iac.conf
# Distribution sources (e.g. ubuntu-ntp-pools.sources with NTS) are picked
# up via sourcedir below and act as fallback when our own servers are
# unreachable.
# =============================================================================

# Modular config: load every *.conf in conf.d and every *.sources in
# sources.d (distro pools + DHCP-provided sources + our drop-ins).
confdir /etc/chrony/conf.d
sourcedir /etc/chrony/sources.d
sourcedir /run/chrony-dhcp

# Persistence + NTS key storage
driftfile /var/lib/chrony/chrony.drift
ntsdumpdir /var/lib/chrony

# Logging + leap-second handling
logdir /var/log/chrony
leapsectz right/UTC

# Safety directives (distribution defaults)
maxupdateskew 100.0
rtcsync
makestep 1 3
