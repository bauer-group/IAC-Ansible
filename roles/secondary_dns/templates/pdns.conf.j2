   Generated by IAC-Ansible (role: secondary_dns) - DO NOT EDIT MANUALLY
   Allowed-IPs block is managed by `dns-admin primary add/remove` AT RUNTIME
   between the BEGIN/END markers; the rest is fully Ansible-owned. -#}
# ==========================================================================
# PowerDNS Authoritative Server - Secondary/Slave Configuration
# REIN AUTORITATIV - Keine Rekursion, kein Forwarding
# Managed by Ansible (role: secondary_dns) - DO NOT EDIT MANUALLY
# Exception: the BEGIN PRIMARY-IPS / END PRIMARY-IPS block is rewritten by
# `dns-admin primary add/remove` at runtime — Ansible regenerates it from
# the inventory `secondary_dns_primaries` list on every run.
# ==========================================================================

setuid=pdns
setgid=pdns

# Network — IPv4 + IPv6 on every interface
local-address={{ secondary_dns_local_address }}
local-port={{ secondary_dns_local_port }}

# Backend: SQLite3
launch=gsqlite3
gsqlite3-database={{ secondary_dns_db_path }}
gsqlite3-pragma-synchronous=1
gsqlite3-pragma-foreign-keys=1

# Slave/Secondary mode with autosecondary (formerly "supermaster")
secondary=yes
autosecondary=yes

# AXFR/NOTIFY allow-list — managed by dns-admin, regenerated from supermasters
# BEGIN PRIMARY-IPS (managed by dns-admin)
allow-axfr-ips=127.0.0.1,::1{% if secondary_dns_primary_ips %},{{ secondary_dns_primary_ips }}{% endif %}

allow-notify-from=127.0.0.1,::1{% if secondary_dns_primary_ips %},{{ secondary_dns_primary_ips }}{% endif %}

# END PRIMARY-IPS

# DNSSEC: signed zones (KEY/RRSIG/NSEC) are processed automatically.
# The legacy `dnssec` setting was removed in PowerDNS Auth 4.6+.

# Performance — receiver-threads = CPU count
receiver-threads={{ ansible_facts['processor_vcpus'] | default(ansible_facts['processor_cores']) | default(2) }}
cache-ttl=60
negquery-cache-ttl=60
query-cache-ttl=20

# Empty-Non-Terminal cache for signed zones
max-ent-entries=100000

# Logging (production)
log-dns-queries=no
log-dns-details=no
loglevel=4

# API/webserver disabled — dns-admin uses sqlite3 + pdns_control directly
api=no
webserver=no

# Hide version (anti-fingerprinting)
version-string=anonymous
