#!/bin/bash
# =============================================================================
# dns-admin - Secondary DNS Management Tool
# Managed by IAC-Ansible (role: secondary_dns) - DO NOT EDIT MANUALLY
# =============================================================================
# Single source of truth for runtime management of a PowerDNS secondary.
# Zones are pulled automatically via NOTIFY/AXFR — this tool only manages:
#   - Primary servers (add/remove/list/discover/verify)
#   - Zone status (read/refresh)
#   - TSIG keys (list/add/remove)
#   - Server status, health checks, statistics
#
# Improvements over the upstream tool (bauer-group/IP-Helper.SecondaryDNS):
#   - `primary verify`  active reachability + SOA + MNAME diagnostic per primary
#   - `tsig`            full runtime TSIG key lifecycle
#   - stricter IPv4/IPv6 input validation
#
# IMPORTANT: changes made via this tool persist in SQLite. The inventory
# `secondary_dns_primaries` list is reapplied with INSERT OR IGNORE on the
# next ansible-pull — runtime additions survive unless
# `secondary_dns_primaries_strict: true` is set.
# =============================================================================

set -euo pipefail

DB="{{ secondary_dns_db_path }}"
CONF="{{ secondary_dns_conf_path }}"

{% raw %}
# Everything below this line is pure bash. Wrapped in {% raw %}...{% endraw %}
# so Jinja2 does not interpret bash parameter expansions like ${#var}
# (string length) as the start of a Jinja comment block.
# --- Helpers ---------------------------------------------------------------
err()  { echo "ERROR: $*" >&2; exit 1; }
warn() { echo "WARN:  $*" >&2; }
info() { echo "INFO:  $*"; }
need_root() { [[ $EUID -eq 0 ]] || err "command requires root (sudo)"; }

# Strict IPv4: four 0-255 octets
is_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    local IFS='.' octet
    for octet in $ip; do
        [[ "$octet" -le 255 ]] || return 1
    done
    return 0
}

# Pragmatic IPv6 sanity check — at least one colon, only hex+colons.
# Full RFC4291 validation would bloat the script; PowerDNS does the strict
# parse on startup.
is_ipv6() {
    local ip="$1"
    [[ "$ip" == *:* ]] || return 1
    [[ "$ip" =~ ^[0-9a-fA-F:]+$ ]] || return 1
    return 0
}

validate_ip() {
    if ! is_ipv4 "$1" && ! is_ipv6 "$1"; then
        err "invalid IP address: $1 (neither IPv4 nor IPv6)"
    fi
}

validate_hostname() {
    [[ "$1" =~ ^[a-zA-Z0-9.-]+$ ]] || err "invalid hostname: $1"
    [[ "${#1}" -le 253 ]] || err "hostname too long (>253 chars): $1"
}

# Regenerate the BEGIN/END PRIMARY-IPS block in pdns.conf from the DB
regen_pdns_conf() {
    need_root
    local ips
    ips=$(sqlite3 "$DB" "SELECT DISTINCT ip FROM supermasters ORDER BY ip;" | paste -sd ',')
    local prefix=""
    [[ -n "$ips" ]] && prefix=","

    if ! grep -q "^# BEGIN PRIMARY-IPS" "$CONF"; then
        err "sentinel marker 'BEGIN PRIMARY-IPS' missing in $CONF — run ansible-pull to restore"
    fi
    if ! grep -q "^# END PRIMARY-IPS" "$CONF"; then
        err "sentinel marker 'END PRIMARY-IPS' missing in $CONF — run ansible-pull to restore"
    fi

    local tmp
    tmp=$(mktemp)
    awk -v ips="$ips" -v prefix="$prefix" '
        /^# BEGIN PRIMARY-IPS/ {
            print "# BEGIN PRIMARY-IPS (managed by dns-admin)"
            print "allow-axfr-ips=127.0.0.1,::1" prefix ips
            print ""
            print "allow-notify-from=127.0.0.1,::1" prefix ips
            print ""
            print "# END PRIMARY-IPS"
            in_block = 1
            next
        }
        /^# END PRIMARY-IPS/ { in_block = 0; next }
        !in_block { print }
    ' "$CONF" > "$tmp"

    mv "$tmp" "$CONF"
    chown pdns:pdns "$CONF"
    chmod 640 "$CONF"
}

reload_pdns() {
    need_root
    if systemctl reload pdns 2>/dev/null; then
        echo "PowerDNS reloaded"
    else
        systemctl restart pdns
        echo "PowerDNS restarted"
    fi
}

require_dig() {
    command -v dig >/dev/null 2>&1 || err "dig not found (package: dnsutils)"
}

# --- primary subcommands ---------------------------------------------------
cmd_primary_list() {
    local count
    count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM supermasters;" 2>/dev/null || echo 0)
    if [[ "$count" -eq 0 ]]; then
        echo "No primary servers configured."
        return 0
    fi
    echo "Primary DNS servers (${count} entries):"
    echo ""
    sqlite3 -header -column "$DB" \
        "SELECT nameserver AS Hostname, ip AS IP, account AS Account FROM supermasters ORDER BY nameserver, ip;"
}

cmd_primary_add() {
    need_root
    local hostname="${1:-}"
    [[ -z "$hostname" ]] && err "usage: dns-admin primary add <hostname> <ip> [<ip> ...]"
    validate_hostname "$hostname"
    shift
    [[ $# -eq 0 ]] && err "at least one IP required (IPv4 and/or IPv6)"

    local ip
    for ip in "$@"; do
        validate_ip "$ip"
        sqlite3 "$DB" \
            "INSERT OR IGNORE INTO supermasters (ip, nameserver, account) VALUES ('$ip', '$hostname', 'runtime');"
        echo "  + $ip ($hostname)"
    done
    chown pdns:pdns "$DB"

    regen_pdns_conf
    reload_pdns

    echo ""
    info "Tip: for disaster recovery, add this entry to"
    info "     inventory/production/host_vars/$(hostname).yml under"
    info "     secondary_dns_primaries: as well."
}

cmd_primary_remove() {
    need_root
    local target="${1:-}"
    [[ -z "$target" ]] && err "usage: dns-admin primary remove <hostname-or-ip>"
    [[ "$target" =~ ^[a-zA-Z0-9.:.-]+$ ]] || err "invalid value: $target"

    local count
    count=$(sqlite3 "$DB" \
        "SELECT COUNT(*) FROM supermasters WHERE nameserver='$target' OR ip='$target';")
    [[ "$count" -eq 0 ]] && err "no entry found for '$target'"

    sqlite3 "$DB" \
        "DELETE FROM supermasters WHERE nameserver='$target' OR ip='$target';"
    echo "removed: $count entry/entries for '$target'"

    regen_pdns_conf
    reload_pdns
}

cmd_primary_reload() {
    need_root
    regen_pdns_conf
    reload_pdns
}

cmd_primary_discover() {
    local primary_ip="${1:-}"
    local zone="${2:-}"
    if [[ -z "$primary_ip" || -z "$zone" ]]; then
        err "usage: dns-admin primary discover <primary-ip> <known-zone>"
    fi
    validate_ip "$primary_ip"
    validate_hostname "$zone"
    require_dig

    echo "Querying SOA of '${zone}' from primary ${primary_ip}..."
    local soa
    soa=$(dig @"$primary_ip" "$zone" SOA +short +time=5 +tries=2 2>/dev/null | head -1)

    if [[ -z "$soa" ]]; then
        err "no SOA reply from ${primary_ip} for zone ${zone} (timeout, wrong IP, unknown zone, or ACL?)"
    fi

    local mname
    mname=$(echo "$soa" | awk '{print $1}' | sed 's/\.$//')
    [[ -z "$mname" ]] && err "MNAME could not be extracted from SOA: $soa"

    echo ""
    echo "============================================"
    echo "  Discovery Result"
    echo "============================================"
    echo "  Zone:    ${zone}"
    echo "  Primary: ${primary_ip}"
    echo "  MNAME:   ${mname}"
    echo ""

    local existing
    existing=$(sqlite3 "$DB" \
        "SELECT COUNT(*) FROM supermasters WHERE ip='${primary_ip}' AND nameserver='${mname}';" 2>/dev/null || echo 0)

    if [[ "$existing" -gt 0 ]]; then
        echo "  Status:  OK — already in supermasters."
    else
        echo "  Status:  NOT in supermasters — this MNAME will be REFUSED on NOTIFY!"
        echo ""
        echo "  Add with:"
        echo "    sudo dns-admin primary add ${mname} ${primary_ip}"
        echo ""
        echo "  For dual-stack also pass IPv6:"
        echo "    sudo dns-admin primary add ${mname} ${primary_ip} <ipv6>"
        echo ""
        echo "  RECOMMENDED: also add to inventory secondary_dns_primaries"
        echo "  so a re-image restores the entry automatically."
    fi
    echo "============================================"
}

# Active health check per configured primary — tests reachability, SOA reply,
# MNAME consistency. Real diagnostic, not a passive "configured yes/no".
cmd_primary_verify() {
    require_dig
    local zone="${1:-}"
    if [[ -z "$zone" ]]; then
        err "usage: dns-admin primary verify <zone-known-on-all-primaries>"
    fi
    validate_hostname "$zone"

    local pcount
    pcount=$(sqlite3 "$DB" "SELECT COUNT(*) FROM supermasters;" 2>/dev/null || echo 0)
    if [[ "$pcount" -eq 0 ]]; then
        err "no primaries configured (see 'dns-admin primary list')"
    fi

    echo "============================================"
    echo "  Primary Verify — Zone: ${zone}"
    echo "============================================"

    local total_ok=0 total_fail=0 total_mismatch=0
    local ip host soa returned_mname latency_ms serial

    while IFS='|' read -r ip host; do
        echo ""
        echo "--- ${host} @ ${ip} ---"

        # 1. Reachability via SOA query (with latency measurement)
        local start_ts end_ts
        start_ts=$(date +%s%3N 2>/dev/null || date +%s)
        soa=$(dig @"$ip" "$zone" SOA +short +time=5 +tries=2 2>/dev/null | head -1)
        end_ts=$(date +%s%3N 2>/dev/null || date +%s)
        latency_ms=$((end_ts - start_ts))

        if [[ -z "$soa" ]]; then
            echo "  [FAIL]  no SOA reply (timeout/ACL/wrong zone)"
            total_fail=$((total_fail + 1))
            continue
        fi
        echo "  [OK]    SOA reply in ${latency_ms}ms"

        # 2. Extract MNAME and compare against DB entry
        returned_mname=$(echo "$soa" | awk '{print $1}' | sed 's/\.$//')
        if [[ -z "$returned_mname" ]]; then
            echo "  [FAIL]  could not extract MNAME from: $soa"
            total_fail=$((total_fail + 1))
            continue
        fi

        if [[ "$returned_mname" == "$host" ]]; then
            echo "  [OK]    MNAME matches: ${returned_mname}"
            total_ok=$((total_ok + 1))
        else
            echo "  [WARN]  MNAME mismatch:"
            echo "          DB entry:    ${host}"
            echo "          SOA returns: ${returned_mname}"
            echo "          -> NOTIFYs from this IP will be REFUSED with MNAME=${returned_mname}!"
            echo "          Fix: sudo dns-admin primary add ${returned_mname} ${ip}"
            total_mismatch=$((total_mismatch + 1))
        fi

        # 3. Show current serial from the SOA reply
        serial=$(echo "$soa" | awk '{print $3}')
        echo "  [INFO]  current serial: ${serial}"

    done < <(sqlite3 -separator '|' "$DB" "SELECT ip, nameserver FROM supermasters ORDER BY nameserver, ip;")

    echo ""
    echo "============================================"
    echo "  Summary: ${total_ok} OK, ${total_mismatch} MNAME mismatch, ${total_fail} unreachable"
    echo "============================================"

    if [[ $total_fail -gt 0 ]]; then
        return 2
    elif [[ $total_mismatch -gt 0 ]]; then
        return 1
    fi
    return 0
}

# --- zone subcommands (read-only / refresh) --------------------------------
cmd_zone_list() {
    local count
    count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM domains;" 2>/dev/null || echo 0)
    if [[ "$count" -eq 0 ]]; then
        echo "No zones present."
        echo "Zones appear automatically as soon as a primary sends NOTIFY."
        return 0
    fi
    echo "Zones (${count}, auto-synced via NOTIFY/AXFR):"
    echo ""
    sqlite3 -header -column "$DB" "
        SELECT
            d.name AS Zone,
            d.type AS Type,
            d.master AS Master,
            COALESCE(d.last_check, 0) AS LastCheck,
            (SELECT COUNT(*) FROM records WHERE domain_id = d.id) AS Records
        FROM domains d
        ORDER BY d.name;"
}

cmd_zone_show() {
    local zone="${1:-}"
    [[ -z "$zone" ]] && err "usage: dns-admin zone show <zone>"
    validate_hostname "$zone"
    pdnsutil show-zone "$zone"
}

cmd_zone_retrieve() {
    need_root
    local zone="${1:-}"
    [[ -z "$zone" ]] && err "usage: dns-admin zone retrieve <zone>"
    validate_hostname "$zone"
    pdnsutil retrieve-zone "$zone"
}

cmd_zone_check() {
    local zone="${1:-}"
    if [[ -n "$zone" ]]; then
        validate_hostname "$zone"
        pdnsutil check-zone "$zone"
    else
        pdnsutil check-all-zones
    fi
}

cmd_zone_delete() {
    need_root
    local zone="${1:-}"
    [[ -z "$zone" ]] && err "usage: dns-admin zone delete <zone>"
    validate_hostname "$zone"
    echo ""
    echo "WARNING: this zone will reappear on the next NOTIFY from the primary."
    echo "Only useful when the zone has been deleted on the primary as well."
    echo ""
    if [[ -t 0 ]]; then
        read -p "Delete anyway? (y/n): " -n 1 -r reply
        echo
        [[ ! "$reply" =~ ^[YyJj]$ ]] && { echo "aborted."; return 0; }
    fi
    pdnsutil delete-zone "$zone"
}

# --- tsig subcommands (runtime TSIG management) ---------------------------
cmd_tsig_list() {
    local count
    count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM tsigkeys;" 2>/dev/null || echo 0)
    if [[ "$count" -eq 0 ]]; then
        echo "No TSIG keys configured."
        return 0
    fi
    echo "TSIG keys (${count}):"
    echo ""
    # Secret deliberately not shown — only first 8 chars to confirm presence.
    sqlite3 -header -column "$DB" "
        SELECT
            name AS Name,
            algorithm AS Algorithm,
            substr(secret, 1, 8) || '...' AS SecretPrefix
        FROM tsigkeys
        ORDER BY name;"
}

cmd_tsig_add() {
    need_root
    local name="${1:-}"
    local algo="${2:-}"
    local secret="${3:-}"
    if [[ -z "$name" || -z "$algo" || -z "$secret" ]]; then
        err "usage: dns-admin tsig add <name> <algorithm> <base64-secret>
  algorithms: hmac-md5, hmac-sha1, hmac-sha224, hmac-sha256, hmac-sha384, hmac-sha512"
    fi
    validate_hostname "$name"
    case "$algo" in
        hmac-md5|hmac-sha1|hmac-sha224|hmac-sha256|hmac-sha384|hmac-sha512) ;;
        *) err "unknown algorithm: $algo" ;;
    esac
    [[ "$secret" =~ ^[A-Za-z0-9+/=]+$ ]] || err "secret is not valid base64"

    sqlite3 "$DB" \
        "INSERT OR REPLACE INTO tsigkeys (name, algorithm, secret) VALUES ('$name', '$algo', '$secret');"
    chown pdns:pdns "$DB"
    echo "TSIG key '$name' ($algo) stored."
    info "activate per zone: pdnsutil set-meta <zone> AXFR-MASTER-TSIG $name"
    info "tip: for persistence also set secondary_dns_tsig_key in host_vars/group_vars."
}

cmd_tsig_remove() {
    need_root
    local name="${1:-}"
    [[ -z "$name" ]] && err "usage: dns-admin tsig remove <name>"
    validate_hostname "$name"

    local count
    count=$(sqlite3 "$DB" "SELECT COUNT(*) FROM tsigkeys WHERE name='$name';")
    [[ "$count" -eq 0 ]] && err "no TSIG key named '$name' found"

    sqlite3 "$DB" "DELETE FROM tsigkeys WHERE name='$name';"
    echo "TSIG key '$name' removed."
    warn "any zone metadata referencing this key (AXFR-MASTER-TSIG) must be cleaned separately."
}

# --- status / health / stats ----------------------------------------------
cmd_status() {
    echo "============================================"
    echo "  Secondary DNS Server Status"
    echo "============================================"

    if systemctl is-active pdns >/dev/null 2>&1; then
        local since
        since=$(systemctl show pdns --property=ActiveEnterTimestamp --value 2>/dev/null || echo "?")
        echo "PowerDNS:    RUNNING (since ${since})"
    else
        echo "PowerDNS:    STOPPED"
    fi

    echo ""
    echo "--- Listening ---"
    ss -tulpn 2>/dev/null | grep pdns | head -5 || echo "  (no data)"

    echo ""
    echo "--- Primary DNS Servers ---"
    local pcount
    pcount=$(sqlite3 "$DB" "SELECT COUNT(*) FROM supermasters;" 2>/dev/null || echo 0)
    if [[ "$pcount" -eq 0 ]]; then
        echo "  (none configured)"
    else
        sqlite3 "$DB" "SELECT '  ' || nameserver || '  ' || ip FROM supermasters ORDER BY nameserver, ip;"
    fi

    echo ""
    local zcount
    zcount=$(sqlite3 "$DB" "SELECT COUNT(*) FROM domains;" 2>/dev/null || echo 0)
    echo "--- Zones: ${zcount} ---"
    if [[ "$zcount" -gt 0 ]]; then
        sqlite3 "$DB" "SELECT '  ' || name FROM domains ORDER BY name LIMIT 10;"
        [[ "$zcount" -gt 10 ]] && echo "  ... and $((zcount - 10)) more"
    fi

    echo ""
    local tcount
    tcount=$(sqlite3 "$DB" "SELECT COUNT(*) FROM tsigkeys;" 2>/dev/null || echo 0)
    echo "--- TSIG keys: ${tcount} ---"

    echo ""
    echo "--- Statistics ---"
    if command -v pdns_control >/dev/null 2>&1 && pdns_control rping >/dev/null 2>&1; then
        local q ch cm up
        q=$(pdns_control show udp-queries 2>/dev/null || echo "?")
        ch=$(pdns_control show packetcache-hit 2>/dev/null || echo "?")
        cm=$(pdns_control show packetcache-miss 2>/dev/null || echo "?")
        up=$(pdns_control show uptime 2>/dev/null || echo "?")
        echo "  UDP queries:  ${q}"
        echo "  Cache hits:   ${ch}"
        echo "  Cache miss:   ${cm}"
        echo "  Uptime:       ${up}s"
    else
        echo "  (pdns_control not reachable)"
    fi

    echo ""
    echo "--- Security ---"
    if systemctl is-active fail2ban >/dev/null 2>&1; then
        local jails banned_total=0 jail
        jails=$(fail2ban-client status 2>/dev/null | awk -F':' '/Jail list/ {gsub(/[ \t]+/, "", $2); print $2}' | tr ',' ' ')
        if [[ -n "$jails" ]]; then
            for jail in $jails; do
                local n
                n=$(fail2ban-client status "$jail" 2>/dev/null | awk -F':' '/Currently banned/ {gsub(/[ \t]+/, "", $2); print $2}')
                [[ -n "$n" ]] && banned_total=$((banned_total + n)) && echo "  fail2ban [$jail]: ${n} active bans"
            done
        fi
        echo "  fail2ban total: ${banned_total} active bans"
    else
        echo "  fail2ban: NOT RUNNING"
    fi

    echo ""
    echo "--- System ---"
    echo "  Disk:   $(df -h /var/lib/powerdns 2>/dev/null | tail -1 | awk '{print $3 " / " $2 " (" $5 ")"}')"
    echo "  Memory: $(free -h | awk '/^Mem:/ {print $3 " / " $2}')"
    echo "  Time:   $(date '+%Y-%m-%d %H:%M:%S %Z')"
    echo "============================================"
}

cmd_health() {
    local errors=0 warnings=0

    if ! systemctl is-active pdns >/dev/null 2>&1; then
        echo "CRITICAL: PowerDNS is not active"
        errors=$((errors + 1))
    fi

    if ! ss -tulpn 2>/dev/null | grep -q ':53 '; then
        echo "CRITICAL: port 53 not bound"
        errors=$((errors + 1))
    fi

    if ! dig @127.0.0.1 +short +time=2 version.bind chaos txt >/dev/null 2>&1; then
        echo "CRITICAL: DNS not answering on localhost"
        errors=$((errors + 1))
    fi

    local pcount
    pcount=$(sqlite3 "$DB" "SELECT COUNT(*) FROM supermasters;" 2>/dev/null || echo 0)
    if [[ "$pcount" -eq 0 ]]; then
        echo "CRITICAL: no primary servers configured"
        errors=$((errors + 1))
    fi

    if ! systemctl is-active chrony >/dev/null 2>&1; then
        echo "WARNING: chrony is not active (time sync)"
        warnings=$((warnings + 1))
    fi

    if ! systemctl is-active fail2ban >/dev/null 2>&1; then
        echo "WARNING: fail2ban is not active (no bruteforce protection)"
        warnings=$((warnings + 1))
    fi

    local disk_usage
    disk_usage=$(df /var/lib/powerdns 2>/dev/null | tail -1 | awk '{print $5}' | tr -d '%')
    if [[ -n "$disk_usage" && "$disk_usage" -gt 90 ]]; then
        echo "WARNING: disk usage at ${disk_usage}%"
        warnings=$((warnings + 1))
    fi

    local zcount
    zcount=$(sqlite3 "$DB" "SELECT COUNT(*) FROM domains;" 2>/dev/null || echo 0)
    if [[ "$zcount" -eq 0 ]]; then
        echo "WARNING: no zones (waiting for primary NOTIFY)"
        warnings=$((warnings + 1))
    fi

    if [[ "$errors" -gt 0 ]]; then
        echo "HEALTH: CRITICAL (${errors} errors, ${warnings} warnings)"
        exit 2
    elif [[ "$warnings" -gt 0 ]]; then
        echo "HEALTH: WARNING (${warnings} warnings, ${zcount} zones, ${pcount} primaries)"
        exit 1
    else
        echo "HEALTH: OK (${zcount} zones, ${pcount} primaries)"
        exit 0
    fi
}

cmd_stats() {
    command -v pdns_control >/dev/null 2>&1 || err "pdns_control not found"
    echo "============================================"
    echo "  PowerDNS statistics"
    echo "============================================"
    pdns_control show '*' 2>/dev/null | sort
}

cmd_help() {
    cat << 'HELP'
dns-admin - Secondary DNS Management Tool (IAC-Ansible)

USAGE:
    dns-admin <command> [arguments]

PRIMARY MANAGEMENT (root for writes):
    primary list                                List configured primaries
    primary add <hostname> <ip> [<ip> ...]      Add primary (IPv4/IPv6)
    primary remove <hostname-or-ip>             Remove primary
    primary reload                              Regenerate pdns.conf from DB + reload
    primary discover <ip> <known-zone>          Read MNAME from SOA + suggest add cmd
    primary verify <known-zone>                 ACTIVE diagnostic: pings each primary,
                                                compares MNAME, measures latency
                                                (exit 0=ok, 1=mname mismatch, 2=fail)

ZONES (read-only / refresh — created automatically via NOTIFY):
    zone list                                   List zones with status
    zone show <zone>                            Zone details
    zone retrieve <zone>                        Force AXFR (root)
    zone check [<zone>]                         Validate zone(s)
    zone delete <zone>                          Remove orphaned zone (root)

TSIG KEYS (signed AXFR):
    tsig list                                   List configured TSIG keys
    tsig add <name> <algo> <base64>             Create/replace key (root)
                                                algo: hmac-sha256 (recommended) etc.
    tsig remove <name>                          Delete key (root)

STATUS & MONITORING:
    status                                      Full server status
    health                                      Health check (exit 0/1/2)
    stats                                       PowerDNS statistics

EXAMPLES:
    dns-admin primary add ns1.example.com 192.0.2.10 2001:db8::10
    dns-admin primary verify example.com
    dns-admin tsig add transfer-key hmac-sha256 BASE64SECRET==
    dns-admin status
    dns-admin health

NOTE: changes via this tool persist in SQLite. Inventory entries
(secondary_dns_primaries) are reapplied with INSERT OR IGNORE — runtime adds
survive ansible-pull unless secondary_dns_primaries_strict is set.
HELP
}

# --- Dispatcher -----------------------------------------------------------
main() {
    local cmd="${1:-help}"
    case "$cmd" in
        primary)
            shift
            local sub="${1:-list}"
            shift || true
            case "$sub" in
                list|ls)        cmd_primary_list ;;
                add)            cmd_primary_add "$@" ;;
                remove|rm|del)  cmd_primary_remove "$@" ;;
                reload)         cmd_primary_reload ;;
                discover)       cmd_primary_discover "$@" ;;
                verify|check)   cmd_primary_verify "$@" ;;
                *) err "unknown primary subcommand: $sub (see 'dns-admin help')" ;;
            esac
            ;;
        zone)
            shift
            local sub="${1:-list}"
            shift || true
            case "$sub" in
                list|ls)        cmd_zone_list ;;
                show)           cmd_zone_show "$@" ;;
                retrieve|fetch) cmd_zone_retrieve "$@" ;;
                check)          cmd_zone_check "$@" ;;
                delete|rm|del)  cmd_zone_delete "$@" ;;
                *) err "unknown zone subcommand: $sub (see 'dns-admin help')" ;;
            esac
            ;;
        tsig)
            shift
            local sub="${1:-list}"
            shift || true
            case "$sub" in
                list|ls)        cmd_tsig_list ;;
                add)            cmd_tsig_add "$@" ;;
                remove|rm|del)  cmd_tsig_remove "$@" ;;
                *) err "unknown tsig subcommand: $sub (see 'dns-admin help')" ;;
            esac
            ;;
        status)         cmd_status ;;
        health)         cmd_health ;;
        stats)          cmd_stats ;;
        help|-h|--help) cmd_help ;;
        *) err "unknown command: $cmd (see 'dns-admin help')" ;;
    esac
}

main "$@"
{% endraw %}
